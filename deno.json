{
  "name": "@incapost/spoke",
  "version": "1.0.0-alpha.2",
  "exports": "./mod.ts",
  "license": "MIT",
  "tasks": {
    "build": "deno x openapi-typescript ./openapi-v1.json -o ./types.d.ts",
    "ok": "deno fmt --check && deno lint && deno test --doc"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/crypto": "jsr:@std/crypto@^1.1.0",
    "@std/testing": "jsr:@std/testing@^1.0.18",
    "openapi-fetch": "npm:openapi-fetch@^0.17.0"
  },
  "compilerOptions": {
    "noUncheckedIndexedAccess": true
  },
  "fmt": {
    "exclude": ["openapi.json", "types.d.ts"]
  }
}
